version: 2

updates:
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "monthly"
    groups:
      github-actions:
        patterns:
          - "*"

{% if ecosystem == "cargo" %}
  - package-ecosystem: "cargo"
    directory: "/"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 0
    groups:
      rust-security:
        applies-to: security-updates
        patterns:
          - "*"
{% endif %}

{% if ecosystem == "gomod" %}
  - package-ecosystem: "gomod"
    directory: "/"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 0
    groups:
      go-security:
        applies-to: security-updates
        patterns:
          - "*"
{% endif %}
